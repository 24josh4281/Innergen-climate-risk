# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.venv/
venv/

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Large data files (stored locally only) ──────────────────
# Raw CMIP6 NetCDF zip archives — too large for GitHub (~1.2 GB total)
*.nc
*.zip

# ── Web service data files — KEEP in repo (needed for Render deployment) ──
# api/data/*.json and api/data/*.csv are committed (total ~19MB, within GitHub limit)
!api/data/*.json
!api/data/*.csv

# site_output — generated Excel files, do not commit
site_output/

# CLIMADA hazard/exposure data — very large (~25 GB)
climada_python/

# Test zip files (temporary)
test_*.zip

# ── Output plots (auto-generated) ────────────────────────────
# PNG plots are regenerated by scenario_analysis.py
# Uncomment below to exclude PNGs from tracking:
# *.png

# ── IDE / OS ─────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
Thumbs.db
.DS_Store
desktop.ini

# ── CDS API credentials (NEVER commit) ───────────────────────
.cdsapirc
*.cdsapirc

# ── Environment ──────────────────────────────────────────────
.env
*.env

# ── Logs / temp ──────────────────────────────────────────────
*.log
tmp/
temp/
